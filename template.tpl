___SANDBOXED_JS_FOR_WEB_TEMPLATE___

// ─── Imports ───────────────────────────────────────────────────────────────
const callInWindow = require('callInWindow');
const copyFromWindow = require('copyFromWindow');
const getUrl = require('getUrl');
const readTitle = require('readTitle');
const getReferrerUrl = require('getReferrerUrl');
const makeTableMap = require('makeTableMap');
const logToConsole = require('logToConsole');
const getType = require('getType');

// ─── Logging Helper ────────────────────────────────────────────────────────
const log = function(msg, val) {
  if (data.haConsoleLog) {
    if (val !== undefined) {
      logToConsole(msg, val);
    } else {
      logToConsole(msg);
    }
  }
};

// ─── Heap Availability Check ───────────────────────────────────────────────
const heap = copyFromWindow('heap');
if (!heap) {
  log('[Heap Analytics] heap object not found on window. Ensure the Heap snippet is loaded before this tag fires.');
  data.gtmOnFailure();
  return;
}

const tagType = data.haTagType;
log('[Heap Analytics] Tag type:', tagType);

// ─── Utility: Build object from a two-column SIMPLE_TABLE ──────────────────
const buildObjectFromTable = function(tableData, keyCol, valCol) {
  if (!tableData || tableData.length === 0) return {};
  var result = {};
  tableData.forEach(function(row) {
    var k = row[keyCol];
    var v = row[valCol];
    if (k) result[k] = v;
  });
  return result;
};

// ─── IDENTIFY ──────────────────────────────────────────────────────────────
if (tagType === 'haTypeID') {
  var userId = data.haIdentityConfigUID;
  log('[Heap Analytics] identify() - User ID:', userId);
  callInWindow('heap.identify', userId);
}

// ─── TRACK EVENT ───────────────────────────────────────────────────────────
else if (tagType === 'haTypeEvent') {
  var eventName = data.haEventTrackName;

  if (data.haEventPropEnable && data.haEventPropTable && data.haEventPropTable.length > 0) {
    var eventProps = buildObjectFromTable(data.haEventPropTable, 'haEventPropKey', 'haEventPropValue');
    log('[Heap Analytics] track() with properties - Event:', eventName, '| Properties:', eventProps);
    callInWindow('heap.track', eventName, eventProps);
  } else {
    log('[Heap Analytics] track() - Event:', eventName);
    callInWindow('heap.track', eventName);
  }
}

// ─── ADD USER PROPERTIES ───────────────────────────────────────────────────
else if (tagType === 'haTypeUseProp') {
  var userProps = buildObjectFromTable(data.haAddUserPropTable, 'haUPKeyColumn', 'haUPValueColumn');
  log('[Heap Analytics] addUserProperties() - Properties:', userProps);
  callInWindow('heap.addUserProperties', userProps);
}

// ─── ADD EVENT PROPERTIES ──────────────────────────────────────────────────
else if (tagType === 'haTypeEventProp') {
  var eventPropAdd = buildObjectFromTable(data.haAddEventPropTableConfig, 'haAddPropertyCKey', 'haAddPropertyCValue');
  log('[Heap Analytics] addEventProperties() - Properties:', eventPropAdd);
  callInWindow('heap.addEventProperties', eventPropAdd);
}

// ─── REMOVE EVENT PROPERTY ─────────────────────────────────────────────────
else if (tagType === 'haTypeRemEP') {
  var propToRemove = data.haREventProp;
  log('[Heap Analytics] removeEventProperty() - Property:', propToRemove);
  callInWindow('heap.removeEventProperty', propToRemove);
}

// ─── CLEAR EVENT PROPERTIES ────────────────────────────────────────────────
else if (tagType === 'haTypeClearProp') {
  log('[Heap Analytics] clearEventProperties()');
  callInWindow('heap.clearEventProperties');
}

// ─── PAGEVIEW TRACKING ─────────────────────────────────────────────────────
else if (tagType === 'haTypePageView') {
  var pvProps = {};

  // URL
  if (data.haPageURLManual && data.haPageURLValue) {
    pvProps.url = data.haPageURLValue;
  } else {
    pvProps.url = getUrl('href');
  }

  // Title
  if (data.haPageTitleManual && data.haPageTitleValue) {
    pvProps.title = data.haPageTitleValue;
  } else {
    pvProps.title = readTitle();
  }

  // Previous page / referrer
  if (data.haPageRefManual && data.haPagePrev) {
    pvProps.previous_page = data.haPagePrev;
  } else {
    pvProps.previous_page = getReferrerUrl();
  }

  // Page properties (optional)
  if (data.haPageProperties && data.haPagePropConfig && data.haPagePropConfig.length > 0) {
    pvProps.properties = buildObjectFromTable(data.haPagePropConfig, 'haPVPagePropKey', 'haPVPagePropValue');
  }

  log('[Heap Analytics] trackPageview() - Payload:', pvProps);
  callInWindow('heap.trackPageview', pvProps);
}

// ─── ADD PAGEVIEW PROPERTIES ───────────────────────────────────────────────
else if (tagType === 'haTypePageProps') {
  var pageProps = buildObjectFromTable(data.haAddPagePropTable, 'haAddPVPagePropKey', 'haAddPVPagePropValue');
  log('[Heap Analytics] addPageviewProperties() - Properties:', pageProps);
  callInWindow('heap.addPageviewProperties', pageProps);
}

// ─── UNKNOWN TAG TYPE ──────────────────────────────────────────────────────
else {
  log('[Heap Analytics] Unknown tag type:', tagType);
  data.gtmOnFailure();
  return;
}

data.gtmOnSuccess();


